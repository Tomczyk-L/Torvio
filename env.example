# Skopiuj do .env.local i uzupełnij wartości

# ── Baza danych ──────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/automarket"

# ── Clerk (autentykacja) ─────────────────
# https://clerk.com → utwórz projekt → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/logowanie
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/rejestracja
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# ── Cloudinary (zdjęcia) ─────────────────
# https://cloudinary.com → Dashboard → API Keys
CLOUDINARY_CLOUD_NAME=twoja-nazwa
CLOUDINARY_API_KEY=123456789
CLOUDINARY_API_SECRET=abc123...
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=twoja-nazwa

# ── Aplikacja ────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Automarket
